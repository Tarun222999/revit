{
  "expo": {
    "name": "Revit",
    "slug": "revit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/revit-app-icon.png",
    "scheme": "revit",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "buildNumber": "1",
      "bundleIdentifier": "com.tarun.revit",
      "config": {
        "usesNonExemptEncryption": false
      },
      "supportsTablet": true
    },
    "android": {
      "package": "com.tarun.revit",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize",
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#080808",
        "foregroundImage": "./assets/images/revit-android-icon-foreground.png",
        "backgroundImage": "./assets/images/revit-android-icon-background.png",
        "monochromeImage": "./assets/images/revit-android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0d0b09",
          "dark": {
            "backgroundColor": "#0d0b09"
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Revit to choose an avatar from your photo library."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1e3b3312-1672-4370-8fc7-20ca5f53718a"
      }
    },
    "owner": "tarun495"
  }
}
